# AWS Configuration
aws_region   = "us-east-1"
project_name = "demo-k8s"

# Instance Configuration
ami_id        = "ami-0c55b159cbfafe1f0" # Ubuntu 22.04 LTS (update with your region's AMI)
instance_type = "t3.medium"
worker_count  = 2                        # Number of worker nodes (total machines = 1 master + worker_count)
disk_size     = 30

# SSH Key Configuration (choose one method)
# Option 1: Read public key from file
public_key_file = "~/.ssh/id_rsa.pub"    # Path to your SSH public key file

# Option 2: Provide public key inline (uncomment and use if not using public_key_file)
# public_key_inline = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC..."

# Security Group CIDR Blocks
# For better security, restrict these to your IP or VPC CIDR
allowed_ssh_cidr     = ["0.0.0.0/0"]      # SSH access
allowed_k8s_api_cidr = ["0.0.0.0/0"]      # Kubernetes API (6443)
allowed_https_cidr   = ["0.0.0.0/0"]      # HTTPS (443)
allowed_http_cidr    = ["0.0.0.0/0"]      # HTTP (80)

